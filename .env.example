# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ─── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── GitHub Pages Base Path (optional) ────────────────────────
# Set to /your-repo-name/ if hosting in a subpath on GitHub Pages
# e.g. VITE_BASE_PATH=/splittter/
# Leave empty or as / for custom domain or root hosting
VITE_BASE_PATH=/

# ─── Edge Function Secrets (set in Supabase Dashboard) ────────
# These are set in Supabase → Edge Functions → Secrets, NOT in .env.local

# OpenAI API key for LLM categorization (optional; falls back to heuristics)
# OPENAI_API_KEY=sk-...

# Optional: Premium FX API key from exchangerate-api.com for higher rate limits
# FX_API_KEY=your-fx-api-key

# Optional: Secret token for authenticating the GitHub Actions FX refresh call
# FX_REFRESH_SECRET=your-secret-token
